# ─────────────────────────────────────────────────────────────────────────────
# Philosophy School — Frontend environment variables
#
# Copy this file to .env.local and fill in values for local development.
# .env.local is git-ignored and NEVER committed.
#
# NEXT_PUBLIC_* variables are build-time inlined into the browser bundle.
# They are NOT secrets — never put tokens, keys, or passwords here.
# Changing a NEXT_PUBLIC_* value requires a redeploy (Vercel) or a rebuild
# (local dev server restart) to take effect.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the FastAPI backend (Railway or local Docker Compose).
# The Next.js rewrite proxies /api/:path* → ${NEXT_PUBLIC_API_URL}/:path*
# so the browser makes same-origin calls and CORS is never needed.
#
# Default (used when unset): http://localhost:8000
# Production example:        https://zapp-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Details disclosure flag.
# Set to "1" to enable the collapsible debug block on each assistant turn,
# exposing lang_confidence, confidence_score, final_normalized_text, and
# detected_country.  Leave unset (or set to anything other than "1") to keep
# those fields hidden from students (the default, safe configuration).
#
# Default: off (unset)
# Enable:  NEXT_PUBLIC_SHOW_DETAILS=1
NEXT_PUBLIC_SHOW_DETAILS=
