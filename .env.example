# Environment template for the Zapp Global Philosophy School platform.
#
#   cp .env.example .env      # then fill in real values
#
# `.env` is gitignored (this template is NOT) — NEVER commit real secrets.
# Backend vars map 1:1 to `backend/app/config.py` Settings fields (uppercased) and are
# loaded by pydantic-settings; the same file is layered into docker-compose via
# `env_file: .env` and overrides the compose `${VAR:-default}` interpolation defaults.
# PydanticAI Gateway (recommended): ONE key routes to all providers; Logfire tracing is
# automatic via the gateway's traceparent injection. Fallback: drop the gateway key and
# use direct provider strings + a provider-specific API key. The backend boots + migrates
# + serves stub /chat with NO LLM key at all.
# Frontend `NEXT_PUBLIC_*` vars are BUILD-TIME inlined into the browser bundle — they are
# public by definition, so never put a secret behind a `NEXT_PUBLIC_` name.
#
# req: platform-scaffold-017

# ── Backend (required) ────────────────────────────────────────────────────────
# Only DATABASE_URL + ADMIN_TOKEN are required for the backend to construct settings
# and boot (no LLM key needed for migrations or the stub /chat path).
#
# Async Postgres DSN (asyncpg driver). Host `db` is the docker-compose service name;
# use `localhost` instead when running uvicorn directly on the host.
DATABASE_URL=postgresql+asyncpg://zapp:zapp@db:5432/zapp
# Shared secret guarding admin-only endpoints.
ADMIN_TOKEN=change-me-admin

# ── LLM via Pydantic AI Gateway (ONE key, all providers, auto Logfire tracing) ──
# Get the key from logfire.pydantic.dev (AI Gateway). Format: pylf_v1_us_...
# The gateway injects traceparent so client logfire.configure() + instrument_pydantic_ai()
# produces one distributed trace per turn without extra wiring.
PYDANTIC_AI_GATEWAY_API_KEY=
# Optional: auto-inferred from the key's region prefix (pylf_v1_us_... -> US endpoint).
# Override only if you need to point at a custom or EU gateway endpoint.
PYDANTIC_AI_GATEWAY_BASE_URL=
# Model strings use gateway/<provider>:<model> when the gateway key is set:
ORCHESTRATOR_MODEL=gateway/anthropic:claude-opus-4-6
WORKER_MODEL=gateway/anthropic:claude-sonnet-4-6
JUDGE_MODEL=gateway/anthropic:claude-haiku-4-6
# Fallback: drop the gateway key + use direct provider strings (anthropic:...) + a provider key below.
# PydanticAI reads whichever key matches the model-string prefix from env. Leaving them
# blank is fine when /chat is the stub (no live LLM call).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Backend (optional observability / geo) ────────────────────────────────────
# Blank or absent = feature initializes in safe no-op mode (no error).
LOGFIRE_TOKEN=
POSTHOG_KEY=
IPINFO_TOKEN=

# ── Frontend (build-time; NEVER secrets) ──────────────────────────────────────
# Browser-facing backend URL. Under compose the browser reaches the host-published
# port, so this is localhost:8000 (not the in-network `backend` hostname).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Public PostHog project key for client-side analytics (blank = analytics disabled).
NEXT_PUBLIC_POSTHOG_KEY=
