# Environment template for the Zapp Global Philosophy School platform.
#
#   cp .env.example .env      # then fill in real values
#
# `.env` is gitignored (this template is NOT) — NEVER commit real secrets.
# Backend vars map 1:1 to `backend/app/config.py` Settings fields (UPPERCASED) and are
# loaded by pydantic-settings; the same file is layered into docker-compose via
# `env_file: .env`. Every var below except DATABASE_URL + ADMIN_TOKEN has a safe default
# in config.py — uncomment only to override. The backend boots + migrates + serves the
# stub /chat with NO LLM key at all.
# Frontend `NEXT_PUBLIC_*` vars are BUILD-TIME inlined into the browser bundle — public by
# definition, so never put a secret behind a `NEXT_PUBLIC_` name.
#
# req: platform-scaffold-017

# ── Backend (REQUIRED) ─────────────────────────────────────────────────────────
# Async Postgres DSN (asyncpg driver). Host `db` = docker-compose service name; use
# `localhost` when running uvicorn directly on the host.
DATABASE_URL=postgresql+asyncpg://zapp:zapp@db:5432/zapp
# Shared secret guarding admin-only endpoints (doc upload/list/delete).
ADMIN_TOKEN=change-me-admin

# ── LLM + embeddings via Pydantic AI Gateway (ONE key, all providers) ───────────
# The ONLY LLM/embedding credential. Get it from logfire.pydantic.dev (AI Gateway).
# Format: pylf_v1_us_... — region auto-inferred from the prefix. The gateway injects
# traceparent so logfire produces one distributed trace per turn. No direct-provider key.
# This SAME key powers the OpenAI embeddings used by FAQ-RAG (text-embedding-3-small).
PYDANTIC_AI_GATEWAY_API_KEY=
# Optional: override only for a custom/EU gateway endpoint (else inferred from the key).
# PYDANTIC_AI_GATEWAY_BASE_URL=
# Model strings: gateway/<provider>:<model>.
# ORCHESTRATOR_MODEL=gateway/openai:gpt-4.1
# WORKER_MODEL=gateway/openai:gpt-4.1-mini
# JUDGE_MODEL=gateway/openai:gpt-4.1-mini

# ── Observability / geo (optional; blank = safe no-op) ─────────────────────────
LOGFIRE_TOKEN=
POSTHOG_KEY=
# Geo-IP fusion uses ipapi.co (keyless). IPINFO_TOKEN is unused by the current provider.
# IPINFO_TOKEN=

# ── Multilingual (optional overrides; defaults in config.py) ───────────────────
# Supported langs (es/en/pt) live in config.py SUPPORTED_LANGS — not set via env.
# FALLBACK_LANG=en
# LANG_CONFIDENCE_MIN=0.55          # below → ask user to confirm language
# MIN_INPUT_CHARS=12                # shorter input → no reliable detection
# LANG_AUTOSWITCH=true              # offer + switch language when the user changes it
# AUTOSWITCH_MIN_TURNS=2            # consecutive turns before auto-switch fires

# ── Evaluation (runtime end-of-conversation judge) ─────────────────────────────
# RUNTIME_EVAL_ENABLED=true
# CONVERSATION_IDLE_TIMEOUT=900     # seconds idle before the idle-sweep grades a session

# ── Guardrails ─────────────────────────────────────────────────────────────────
# GUARDRAILS_ENABLED=true           # master kill-switch (false = skip all checks)
# GUARDRAILS_LLM_ENABLED=false      # optional LLM guardrail layer atop the deterministic core

# ── Signal fusion (geo-IP + REST Countries) ────────────────────────────────────
# GEO_FUSION_ENABLED=true
# REST_COUNTRIES_ENABLED=true
# IPAPI_BASE_URL=https://ipapi.co
# REST_COUNTRIES_BASE_URL=https://restcountries.com/v3.1
# GEO_TIMEOUT=3.0
# DEFAULT_LOCALE=en-US
# DEFAULT_TIMEZONE=UTC

# ── FAQ-RAG (pgvector retrieval; embeddings via the gateway, NO separate key) ───
# Embeddings use OpenAI text-embedding-3-small routed through the gateway above — the
# SAME PYDANTIC_AI_GATEWAY_API_KEY, no extra credential.
# EMBEDDING_MODEL=gateway/openai:text-embedding-3-small
# EMBEDDING_DIM=1536                # MUST match the model + the pgvector column dimension
# RAG_TOP_K=5
# RAG_SIMILARITY_MIN=0.25           # min cosine similarity for a chunk to count as a hit
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=150
# HYBRID_RETRIEVAL=false            # on = cosine + keyword scoring

# ── Frontend (build-time; NEVER secrets) ───────────────────────────────────────
# Server-side proxy target for the Next.js rewrite (/api/* -> ${NEXT_PUBLIC_API_URL}/*).
# The rewrite runs inside the frontend container, so under docker-compose this is set to
# the in-network service hostname `http://backend:8000` (NOT localhost). The browser only
# ever calls same-origin /api/*, so it never resolves `backend`. For host-run `pnpm dev`
# against a host backend, use http://localhost:8000.
NEXT_PUBLIC_API_URL=http://backend:8000
# Set to 1 to expose the per-turn debug fields (lang_confidence, confidence_score,
# final_normalized_text, detected_country) behind a collapsible disclosure in the chat.
# NEXT_PUBLIC_SHOW_DETAILS=0
# NOTE: there is NO client-side PostHog — analytics is backend-only (POSTHOG_KEY above).
